# football-data.org — free, 10 req/min — https://www.football-data.org/client/login
VITE_FOOTBALL_DATA_API_KEY=your_key_here
# API-Football (api-sports.io) — free, 100 req/day — https://dashboard.api-football.com/register
VITE_API_FOOTBALL_KEY=your_key_here
VITE_ODDS_API_KEY=your_key_here
VITE_FIREBASE_API_KEY=your_key_here
